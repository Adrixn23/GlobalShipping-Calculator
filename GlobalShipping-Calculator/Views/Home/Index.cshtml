@model GlobalShipping_Calculator.Models.ShippingViewModel

@{
    ViewData["Title"] = "Calculadora";
}

<div class="row justify-content-center fade-in">
    <div class="col-lg-6 col-md-8">
        
        <div class="dashboard-card">
            
            <div class="text-center">
                <h1 class="display-title">Cálculo de Tarifas</h1>
                <p class="text-subtitle">Cotizador internacional de envíos</p>
            </div>

            <form asp-action="Index" method="post">
                
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                        <!-- Icono SVG Alerta -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                        <div>@Model.ErrorMessage</div>
                    </div>
                }

                <div class="mb-4">
                    <label asp-for="SelectedCountryCode" class="control-label">
                        <!-- Icono SVG Mapa -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        País de Destino
                    </label>
                    <select asp-for="SelectedCountryCode" class="form-select" required>
                        <option value="" disabled selected>-- Seleccione el destino --</option>
                        @foreach (var country in Model.AvailableCountries)
                        {
                            <option value="@country.Code">@country.Name</option>
                        }
                    </select>
                    <span asp-validation-for="SelectedCountryCode" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Weight" class="control-label">
                        <!-- Icono SVG Peso -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                        Peso del Paquete (Kg)
                    </label>
                    <div class="input-group">
                        <input asp-for="Weight" type="number" step="0.1" min="0.1" class="form-control" placeholder="0.0" required />
                        <span class="input-group-text text-muted bg-white">Kg</span>
                    </div>
                    <span asp-validation-for="Weight" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <!-- Icono SVG Calculadora -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="8" y1="6" x2="16" y2="6"></line><line x1="16" y1="14" x2="16" y2="18"></line><line x1="8" y1="10" x2="16" y2="10"></line><line x1="8" y1="14" x2="8" y2="18"></line><line x1="12" y1="14" x2="12" y2="18"></line></svg>
                        Procesar Cotización
                    </button>
                </div>
            </form>

            @if (Model.QuoteResult != null)
            {
                <div class="result-panel text-center">
                    <h6 class="text-uppercase text-muted fw-bold mb-3">Resultado de la Operación</h6>
                    
                    <div class="d-flex justify-content-center gap-4 mb-3">
                        <div>
                            <span class="text-muted small d-block">Destino</span>
                            <span class="fw-bold">@Model.QuoteResult.CountryName</span>
                        </div>
                        <div class="border-start"></div>
                        <div>
                            <span class="text-muted small d-block">Peso</span>
                            <span class="fw-bold">@Model.QuoteResult.Weight Kg</span>
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <span class="text-muted small d-block mb-1">Tarifa Final (USD)</span>
                        <div class="result-value">
                            $@Model.QuoteResult.TotalCost.ToString("0.00")
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}